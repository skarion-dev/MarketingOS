# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Crypto (64 hex characters = 32 bytes for AES-256-GCM)
SECRET_VAULT_KEY=

# Vertex AI
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS_JSON=
VERTEX_TEXT_MODEL=gemini-2.5-pro-preview-05-06
VERTEX_IMAGE_MODEL=imagen-3.0-generate-001
VERTEX_EMBED_MODEL=text-embedding-004
AI_PROVIDER=google

# Publishing feature flags
PUBLISH_DRY_RUN=true
X_PUBLISHING_ENABLED=false
TALENTOS_HANDOFF_ENABLED=false
